[user]
	name = minato-devv
[alias]
	lg = log --oneline --graph --decorate --all
	a = add
	s = status
	sw = switch
	b = branch
	cl = clone
	c = commit -m
	p = push
	pl = pull
[core]
	editor = nvim
	excludesfile = .gitignore_global
[init]
	defaultBranch = main
[pull]
	rebase = true
[fetch]
	prune = true
[include]
	path = .gitconfig_private
[pager]
	diff = false
